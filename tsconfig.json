{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "es2022"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@/app/*": ["app/*"],
			"@/components/*": ["components/*"],
			"@/features/*": ["features/*"],
			"@/lib/*": ["lib/*"],
			"@/services/*": ["services/*"],
			"@/hooks/*": ["hooks/*"],
			"@/types/*": ["types/*"],
			"@/utils/*": ["utils/*"],
			"@/config/*": ["config/*"],
			"@/constants/*": ["constants/*"],
			"@/styles/*": ["styles/*"],
			"@/prisma/*": ["prisma/*"],
			"@/firebase/*": ["firebase/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}